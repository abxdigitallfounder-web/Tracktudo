# ============================================================
# TRACKTUDO - Configuração do backend
# Copie este arquivo para ".env" e preencha os valores.
# NUNCA comite o arquivo .env (ele está no .gitignore).
# ============================================================

# Token principal da Meta. Passado como access_token nas chamadas da Graph API.
# Pode ser um token de System User (nunca expira) ou de usuário (~60 dias).
META_SYSTEM_USER_TOKEN=

# Tokens ADICIONAIS (opcional). O app une as contas de TODOS os tokens, sem
# duplicar. Útil quando as contas estão espalhadas por vários Business Managers
# e nenhum token único enxerga todas.
# Formato: lista separada por vírgula; cada item é "rotulo|token" ou só "token".
# Ex.: META_TOKENS=arthur|EAA...,agencia|EAB...
META_TOKENS=

# ID do Business Manager (OPCIONAL).
# As contas são listadas via me/adaccounts (todas que o token enxerga, em todos
# os Business Managers), então este ID não é necessário. Deixe em branco ou
# preencha se um dia quiser filtrar por um BM específico.
META_BUSINESS_ID=

# Versão da Graph API (padrão v25.0)
META_API_VERSION=v25.0

# Porta do servidor backend
PORT=3000

# ------------------------------------------------------------
# Acesso / produção
# ------------------------------------------------------------
# Senha única para acessar o dashboard. Se VAZIO, o login fica DESATIVADO
# (use vazio apenas localmente). Em produção, defina uma senha forte.
APP_PASSWORD=

# Segredo para assinar o cookie de login (qualquer string longa e aleatória).
# Em produção o Render gera automaticamente (ver render.yaml).
SESSION_SECRET=

# Ambiente: "development" (padrão) ou "production".
# Em production o backend também serve o frontend compilado (client/dist).
NODE_ENV=development

# Caminho do arquivo SQLite (opcional). Padrão: ./data/tracktudo.db.
# Em hosts com disco persistente, aponte para o volume (ex.: /var/data/tracktudo.db).
DATABASE_PATH=

# ------------------------------------------------------------
# Agendamento (cron) - opcionais, têm padrão no código
# ------------------------------------------------------------
# Coleta de limites (padrão: a cada 12h)
CRON_LIMITS=0 */12 * * *
# Coleta de gastos diários (padrão: a cada 6h)
CRON_DAILY_SPEND=0 */6 * * *
# Dias de backfill inicial de gastos (padrão: 30)
BACKFILL_DAYS=30

# ------------------------------------------------------------
# Rate limit / throttling (opcionais)
# ------------------------------------------------------------
# Intervalo entre chamadas por conta, em ms (padrão: 250)
REQUEST_DELAY_MS=250
# Limite de uso da cota (%) para começar a desacelerar (padrão: 80)
USAGE_THRESHOLD=80
