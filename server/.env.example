# ============================================================
# TRACKTUDO - Configuração do backend
# Copie este arquivo para ".env" e preencha os valores.
# NUNCA comite o arquivo .env (ele está no .gitignore).
# ============================================================

# Token do System User (Usuário do Sistema) de longa duração.
# Gerado no Gerenciador de Negócios > Usuários do Sistema, com a permissão ads_read.
# É passado como access_token nas chamadas da Graph API.
META_SYSTEM_USER_TOKEN=

# ID do Business Manager (OPCIONAL).
# As contas são listadas via me/adaccounts (todas que o token enxerga, em todos
# os Business Managers), então este ID não é necessário. Deixe em branco ou
# preencha se um dia quiser filtrar por um BM específico.
META_BUSINESS_ID=

# Versão da Graph API (padrão v25.0)
META_API_VERSION=v25.0

# Porta do servidor backend
PORT=3000

# ------------------------------------------------------------
# Agendamento (cron) - opcionais, têm padrão no código
# ------------------------------------------------------------
# Coleta de limites (padrão: a cada 12h)
CRON_LIMITS=0 */12 * * *
# Coleta de gastos diários (padrão: a cada 6h)
CRON_DAILY_SPEND=0 */6 * * *
# Dias de backfill inicial de gastos (padrão: 30)
BACKFILL_DAYS=30

# ------------------------------------------------------------
# Rate limit / throttling (opcionais)
# ------------------------------------------------------------
# Intervalo entre chamadas por conta, em ms (padrão: 250)
REQUEST_DELAY_MS=250
# Limite de uso da cota (%) para começar a desacelerar (padrão: 80)
USAGE_THRESHOLD=80
